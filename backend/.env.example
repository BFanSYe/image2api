# image2api Backend 环境变量样例（生产/预发请通过 KMS / Secret 注入，不要 commit）
# 复制为 .env.local（已 gitignore）后修改

# 运行环境
IMAGE2API_ENV=dev                      # local | dev | staging | prod

# 监听端口（参考 docs/01 - 端口规范）
IMAGE2API_API_PORT=17180
IMAGE2API_ADMIN_PORT=17188
IMAGE2API_OPENAI_PORT=17200
IMAGE2API_WS_PORT=17280
IMAGE2API_PPROF_PORT=17590

# 数据库（MySQL 13306）
IMAGE2API_DB_DSN=image2api:image2api123@tcp(127.0.0.1:13306)/image2api?charset=utf8mb4&parseTime=True&loc=Local

# Redis（16379）
IMAGE2API_REDIS_ADDR=127.0.0.1:16379
IMAGE2API_REDIS_PASSWORD=
IMAGE2API_REDIS_DB=0

# JWT（≥ 32 字节，生产请用 openssl rand -hex 32 重新生成）
IMAGE2API_JWT_SECRET=please-change-me-32bytes-min-secret-xx
IMAGE2API_JWT_REFRESH_SECRET=please-change-me-32bytes-min-refresh-xx
IMAGE2API_JWT_ACCESS_TTL=2h
IMAGE2API_JWT_REFRESH_TTL=336h

# 加密账号池凭证（AES-256-GCM）
IMAGE2API_AES_KEY=00000000000000000000000000000000  # 32 字节 hex / base64

# 第三方 Provider 默认 base
IMAGE2API_OPENAI_BASE=https://api.openai.com
IMAGE2API_GROK_BASE=https://api.x.ai

# Provider 模式：mock（本地默认）| real（生产开启真实 HTTP 调用）
IMAGE2API_PROVIDER_GPT=mock
IMAGE2API_PROVIDER_GROK=mock
# 真实模式下的默认 base url（账号未单独配置时使用）
IMAGE2API_GPT_BASE_URL=https://api.openai.com
IMAGE2API_GROK_BASE_URL=https://api.x.ai

# 雪花机器 ID（多副本部署需保证不同）
IMAGE2API_NODE_ID=1

# 日志
IMAGE2API_LOG_LEVEL=info
IMAGE2API_LOG_DIR=./logs
IMAGE2API_LOG_MAX_SIZE_MB=200
IMAGE2API_LOG_MAX_AGE_DAYS=30
IMAGE2API_LOG_COMPRESS=true

# CORS 白名单（逗号分隔）
IMAGE2API_CORS_ORIGINS=http://localhost:5173,http://localhost:5174,https://image2api.example,https://admin.image2api.example
