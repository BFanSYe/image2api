# ==============================================
#   image2api 部署环境变量样例
#   生产请通过 KMS 注入，禁止 commit 实际值
# ==============================================

# 全局
IMAGE2API_ENV=prod

# 端口（仅修改对外）
IMAGE2API_USER_WEB_PORT=17080
IMAGE2API_ADMIN_WEB_PORT=17088
IMAGE2API_OPENAI_PORT=17200

# 内部端口（默认无需改）
IMAGE2API_API_PORT=17180
IMAGE2API_ADMIN_PORT=17188
IMAGE2API_WS_PORT=17280
IMAGE2API_PPROF_PORT=17590

# MySQL
IMAGE2API_MYSQL_PORT=13306
IMAGE2API_MYSQL_ROOT_PASSWORD=replace_me_with_strong_pwd
IMAGE2API_MYSQL_DB=image2api
IMAGE2API_MYSQL_USER=image2api
IMAGE2API_MYSQL_PASSWORD=replace_me_with_strong_pwd
IMAGE2API_DB_DSN=image2api:replace_me_with_strong_pwd@tcp(mysql:3306)/image2api?charset=utf8mb4&parseTime=True&loc=Local

# Redis
IMAGE2API_REDIS_PORT=16379
IMAGE2API_REDIS_ADDR=redis:6379
IMAGE2API_REDIS_PASSWORD=

# 安全
IMAGE2API_JWT_SECRET=$(openssl rand -hex 32)
IMAGE2API_JWT_REFRESH_SECRET=$(openssl rand -hex 32)
IMAGE2API_AES_KEY=$(openssl rand -hex 32)

# Provider
IMAGE2API_OPENAI_BASE=https://api.openai.com
IMAGE2API_GROK_BASE=https://api.x.ai

# 跨域
IMAGE2API_CORS_ORIGINS=https://image2api.example,https://admin.image2api.example

# 日志
IMAGE2API_LOG_DIR=/data/image2api/logs
